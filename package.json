{
	"name": "cf-astro-blog-starter",
	"version": "0.2.0",
	"type": "module",
	"private": true,
	"description": "Astro + Hono + Cloudflare Workers blog with Firefly theme, built-in CMS, admin panel, and analytics",
	"scripts": {
		"dev": "astro dev",
		"build": "node scripts/generate-icons.js && astro build",
		"preview": "astro build && wrangler dev",
		"deploy": "npm run db:migrate:remote && node scripts/generate-icons.js && astro build && wrangler deploy",
		"check": "astro check && bunx biome check src/ tests/",
		"check:fix": "bunx biome check --fix src/ tests/",
		"format": "bunx biome format --write src/ tests/",
		"lint": "bunx biome lint src/ tests/",
		"type-check": "tsc --noEmit",
		"test": "bun test",
		"new-post": "node scripts/new-post.js",
		"icons": "node scripts/generate-icons.js",
		"lqips": "npx tsx scripts/generate-lqips.ts",
		"fonts": "npx tsx scripts/subset-fonts.ts",
		"db:generate": "drizzle-kit generate",
		"db:migrate:local": "wrangler d1 migrations apply DB --local",
		"db:migrate:remote": "wrangler d1 migrations apply DB --remote",
		"db:seed:local": "wrangler d1 execute DB --local --file=scripts/seed.sql",
		"db:seed:remote": "wrangler d1 execute DB --remote --file=scripts/seed.sql"
	},
	"cloudflare": {
		"bindings": {
			"DB": {
				"description": "D1 database for blog posts, categories, tags, and analytics"
			},
			"MEDIA_BUCKET": {
				"description": "R2 bucket for media uploads (images, files)"
			},
			"SESSION": {
				"description": "KV namespace for session storage and caching"
			},
			"JWT_SECRET": {
				"description": "Generate a random string using `openssl rand -hex 32`"
			},
			"ADMIN_USERNAME": {
				"description": "Username for the admin panel login"
			},
			"ADMIN_PASSWORD_HASH": {
				"description": "SHA-256 hash of your admin password. Generate with: `echo -n 'yourpassword' | sha256sum`"
			},
			"TURNSTILE_SECRET_KEY": {
				"description": "Cloudflare Turnstile secret key from the Turnstile dashboard"
			}
		}
	},
	"dependencies": {
		"@astrojs/check": "^0.9.9",
		"@astrojs/cloudflare": "^13.7.0",
		"@astrojs/rss": "^4.0.18",
		"@astrojs/sitemap": "^3.7.3",
		"@astrojs/svelte": "8.1.2",
		"@expressive-code/core": "^0.43.1",
		"@expressive-code/plugin-collapsible-sections": "^0.43.1",
		"@expressive-code/plugin-line-numbers": "^0.43.1",
		"@fancyapps/ui": "^6.1.14",
		"@fontsource-variable/jetbrains-mono": "^5.2.6",
		"@iconify-json/fa7-brands": "^1.2.2",
		"@iconify-json/fa7-regular": "^1.2.3",
		"@iconify-json/fa7-solid": "^1.2.4",
		"@iconify-json/material-symbols": "^1.2.79",
		"@iconify-json/mingcute": "^1.2.7",
		"@iconify-json/simple-icons": "^1.2.86",
		"@iconify/utils": "^3.1.1",
		"@swup/astro": "^1.8.0",
		"@tailwindcss/typography": "^0.5.20",
		"astro": "6.4.8",
		"astro-expressive-code": "^0.43.1",
		"astro-icon": "^1.1.5",
		"ci-info": "^4.4.0",
		"dayjs": "^1.11.21",
		"drizzle-orm": "^0.45.1",
		"glob": "^11.1.0",
		"hastscript": "^9.0.1",
		"hono": "^4.11.6",
		"jose": "^6.1.3",
		"katex": "^0.17.0",
		"mdast-util-to-string": "^4.0.0",
		"pako": "^2.1.0",
		"qrcode": "^1.5.4",
		"reading-time": "^1.5.0",
		"rehype-autolink-headings": "^7.1.0",
		"rehype-callouts": "^2.2.0",
		"rehype-components": "^0.3.0",
		"rehype-katex": "^7.0.1",
		"rehype-slug": "^6.0.0",
		"remark-admonition-to-blockquote-callout": "^1.0.0",
		"remark-directive": "^3.0.1",
		"remark-math": "^6.0.0",
		"remark-sectionize": "^2.1.0",
		"sanitize-html": "^2.17.5",
		"stylus": "^0.64.0",
		"svelte": "^5.56.3",
		"typescript": "^5.9.3",
		"unist-util-visit": "^5.1.0"
	},
	"devDependencies": {
		"@astrojs/ts-plugin": "^1.10.9",
		"@biomejs/biome": "^2.5.0",
		"@cloudflare/workers-types": "^4.20260111.0",
		"@iconify-json/mdi": "^1.2.3",
		"@iconify-json/svg-spinners": "^1.2.4",
		"@tailwindcss/vite": "^4.3.1",
		"@types/hast": "^3.0.4",
		"@types/mdast": "^4.0.4",
		"@types/qrcode": "^1.5.6",
		"@types/sanitize-html": "^2.16.1",
		"drizzle-kit": "^0.30.0",
		"postcss-import": "^16.1.1",
		"postcss-nesting": "^14.0.0",
		"tailwindcss": "^4.3.1",
		"wrangler": "^4.50.0"
	}
}
